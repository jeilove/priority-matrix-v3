// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  todos     Todo[]
}

model Todo {
  id           String   @id // 클라이언트 생성 ID 보존 (uuid)
  userId       String
  text         String
  estimate     String   @default("")
  energy       String   @default("energy-medium")
  status       String   @default("todo") // "todo", "done"
  quadrant     String   @default("q1")   // "q1", "q2", "q3", "q4", "unassigned", "inbox"
  repetition   String[] @default([])     // ["Mon", "Tue", ...]
  context      String[] @default([])     // ["Work", "Home", ...]
  tags         String[] @default([])
  description  String?
  priorityRank Int      @default(9999)
  isHidden     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
